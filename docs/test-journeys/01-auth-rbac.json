        },
        {
          "action": "fill",
          "selector": "#newPassword",
          "value": "NewSecure@2026!A"
        },
        {
          "action": "fill",
          "selector": "#confirmPassword",
          "value": "NewSecure@2026!A"
        },
        {
          "action": "click",
