  "testCases": [
    {
      "id": "RPTX-01",
      "name": "Manager navigates to /reports — verify sidebar has new categories",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/reports",
          "expected": "HTTP 200, reports page loads"
        },
        {
          "action": "wait",
          "selector": "[data-testid=\"reports-left-nav\"]"
        },
        {
          "action": "assert",
          "check": "element '[data-testid=\"reports-left-nav\"]' visible"
        },
        {
          "action": "assert",
          "check": "text '完成率' visible"
        },
        {
          "action": "assert",
          "check": "text '工時詳細' visible"
        },
        {
          "action": "assert",
          "check": "text '分析' visible"
        },
        {
          "action": "assert",
          "check": "text 'V2 進階' visible"
        },
        {
          "action": "screenshot",
          "name": "rptx-01-reports-sidebar-categories"
        }
      ]
    },
