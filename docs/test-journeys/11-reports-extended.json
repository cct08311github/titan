{
  "journey": "reports-extended",
  "version": "1.0.0",
  "description": "Extended reports page — 22 new report tabs across 完成率, 工時詳細, 分析, and V2 進階 categories",
  "baseUrl": "http://localhost:3100",
  "credentials": {
    "ENGINEER": { "email": "engineer@titan.local", "password": "Test1234!", "role": "ENGINEER" },
    "MANAGER": { "email": "manager@titan.local", "password": "Test1234!", "role": "MANAGER" },
    "ADMIN": { "email": "admin@titan.local", "password": "Test1234!", "role": "ADMIN" }
