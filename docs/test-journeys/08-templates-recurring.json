{
  "journey": "08-templates-recurring",
  "version": "1.0.0",
  "description": "範本與自動化頁面完整測試旅程：任務範本 CRUD、套用範本、週期性任務規則 CRUD、啟用/停用、產生任務",
  "baseUrl": "http://localhost:3100",
  "credentials": {
    "ENGINEER": { "email": "engineer@titan.local", "password": "Test1234!", "role": "ENGINEER" },
    "MANAGER": { "email": "manager@titan.local", "password": "Test1234!", "role": "MANAGER" },
    "ADMIN": { "email": "admin@titan.local", "password": "Test1234!", "role": "ADMIN" }
  },
  "testCases": [
    {
      "id": "TPL-01",
      "name": "導覽至 /settings/templates，頁面載入並顯示「範本與自動化」標題",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/settings/templates",
          "expected": "HTTP 200，頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "h1",
          "expected": "h1 標題可見"
        },
        {
          "action": "assert",
          "check": "text '範本與自動化' visible",
          "expected": "頁面標題顯示「範本與自動化」"
        },
        {
          "action": "assert",
          "check": "text '管理任務範本與週期性任務規則' visible",
          "expected": "副標題可見"
        },
        {
          "action": "assert",
          "check": "text '任務範本' visible",
          "expected": "任務範本區段標題可見"
        },
        {
          "action": "assert",
          "check": "text '週期性任務' visible",
          "expected": "週期性任務區段標題可見"
        },
        {
          "action": "screenshot",
          "name": "tpl-01-page-landing"
        }
      ]
    },
    {
      "id": "TPL-02",
      "name": "展開任務範本區段，確認表格標題欄可見",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/settings/templates",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "button:has-text(\"任務範本\")",
          "expected": "任務範本折疊按鈕可見"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"任務範本\")",
          "expected": "點擊展開任務範本區段"
        },
        {
          "action": "wait",
          "timeout": 800,
          "expected": "等待展開動畫完成"
        },
        {
          "action": "assert",
          "check": "text '標題' visible",
          "expected": "表格欄位「標題」可見"
        },
        {
          "action": "assert",
          "check": "text '優先' visible",
          "expected": "表格欄位「優先」可見"
        },
        {
          "action": "assert",
          "check": "text '類別' visible",
          "expected": "表格欄位「類別」可見"
        },
        {
          "action": "assert",
          "check": "text '工時' visible",
          "expected": "表格欄位「工時」可見"
        },
        {
          "action": "assert",
          "check": "text '建立者' visible",
          "expected": "表格欄位「建立者」可見"
        },
        {
          "action": "screenshot",
          "name": "tpl-02-template-section-expanded"
        }
      ]
    },
    {
      "id": "TPL-03",
      "name": "建立任務範本（標題=週會準備，優先=P1，類別=PLANNED，工時=2）",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/settings/templates",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "button:has-text(\"建立範本\")",
          "expected": "「建立範本」按鈕可見"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"建立範本\")",
          "expected": "點擊展開建立範本表單"
        },
        {
          "action": "wait",
          "selector": "input[placeholder=\"範本標題（必填）\"]",
          "expected": "範本標題輸入框可見"
        },
        {
          "action": "fill",
          "selector": "input[placeholder=\"範本標題（必填）\"]",
          "value": "週會準備",
          "expected": "填入範本標題「週會準備」"
        },
        {
          "action": "fill",
          "selector": "textarea[placeholder=\"說明（選填）\"]",
          "value": "每週例行會議前的準備事項",
          "expected": "填入說明"
        },
        {
          "action": "select",
          "selector": "select[aria-label=\"優先級\"]",
          "value": "P1",
          "expected": "選擇優先級 P1"
        },
        {
          "action": "select",
          "selector": "select[aria-label=\"類別\"]",
          "value": "PLANNED",
          "expected": "選擇類別「計畫性」"
        },
        {
          "action": "fill",
          "selector": "input[placeholder=\"預估工時（hr）\"]",
          "value": "2",
          "expected": "填入預估工時 2 小時"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"建立\")",
          "expected": "點擊「建立」送出表單"
        },
        {
          "action": "wait",
          "timeout": 2000,
          "expected": "等待 API 回應"
        },
        {
          "action": "assert",
          "check": "text '範本已建立' visible",
          "expected": "成功 toast 顯示「範本已建立」"
        },
        {
          "action": "screenshot",
          "name": "tpl-03-template-created"
        }
      ]
    },
