  "testCases": [
    {
      "id": "RL-01",
      "name": "Manager 導覽至 /knowledge — 閱讀清單區塊在頁面底部可見",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/knowledge",
          "expected": "URL 為 /knowledge，頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "h1",
          "expected": "頁面標題可見"
        },
        {
          "action": "wait",
          "selector": "[data-testid='reading-list-section'], section:has(svg[data-lucide='book-open']), text=閱讀清單",
          "expected": "閱讀清單區塊（BookOpen 圖示或標題文字）可見於頁面底部"
        },
        {
          "action": "assert",
          "check": "text '閱讀清單' visible",
          "expected": "閱讀清單標題文字可見"
        },
        {
          "action": "screenshot",
          "name": "rl-01-knowledge-reading-list-visible"
        }
      ]
    },
    {
      "id": "RL-02",
      "name": "展開閱讀清單區塊 — 表格標題列可見",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/knowledge",
          "expected": "頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "text=閱讀清單",
          "expected": "閱讀清單區塊可見"
        },
        {
          "action": "click",
          "selector": "button:has-text('閱讀清單'), [data-testid='reading-list-toggle']",
          "expected": "點擊展開/收合按鈕"
        },
        {
          "action": "wait",
          "selector": "th:has-text('標題'), th:has-text('建立者'), th:has-text('項目'), th:has-text('指派')",
          "expected": "閱讀清單表格標題列（標題、建立者、項目數、指派數）可見"
        },
        {
          "action": "assert",
          "check": "element 'table' visible",
          "expected": "閱讀清單表格已顯示"
        },
        {
          "action": "screenshot",
          "name": "rl-02-reading-list-table-header"
        }
      ]
    },
    {
      "id": "RL-03",
      "name": "Manager 建立閱讀清單（標題='新人必讀文件', 描述='入職指南'）",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/knowledge",
          "expected": "頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "text=閱讀清單",
          "expected": "閱讀清單區塊可見"
        },
        {
          "action": "click",
          "selector": "button:has-text('新增閱讀清單'), button:has-text('建立清單'), [data-testid='create-reading-list-btn']",
          "expected": "開啟新增閱讀清單表單"
        },
        {
          "action": "wait",
          "selector": "input[name='title'], input[placeholder*='標題'], input[aria-label*='標題']",
          "expected": "標題輸入框可見"
        },
        {
          "action": "fill",
          "selector": "input[name='title'], input[placeholder*='標題'], input[aria-label*='標題']",
          "value": "J09-新人必讀文件"
        },
        {
          "action": "fill",
          "selector": "textarea[name='description'], textarea[placeholder*='描述'], input[name='description']",
          "value": "入職指南"
        },
        {
          "action": "click",
          "selector": "button[type='submit']:has-text('建立'), button[type='submit']:has-text('新增'), button[type='submit']:has-text('確認')",
          "expected": "提交建立閱讀清單表單"
        },
        {
          "action": "wait",
          "selector": "text=新人必讀文件",
          "expected": "新建立的閱讀清單出現在表格中"
        },
        {
          "action": "screenshot",
          "name": "rl-03-create-reading-list"
        }
