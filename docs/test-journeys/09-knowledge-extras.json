{
  "journey": "09-knowledge-extras",
  "version": "1.0.0",
  "description": "知識庫頁面的閱讀清單與文件範本功能端對端測試旅程",
  "baseUrl": "http://localhost:3100",
  "credentials": {
    "ENGINEER": {
      "email": "engineer@titan.local",
      "password": "Test1234!",
      "role": "ENGINEER"
    },
    "MANAGER": {
      "email": "manager@titan.local",
      "password": "Test1234!",
      "role": "MANAGER"
    },
    "ADMIN": {
      "email": "admin@titan.local",
      "password": "Test1234!",
      "role": "ADMIN"
