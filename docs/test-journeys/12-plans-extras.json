        {
          "action": "wait",
          "selector": "[data-testid=\"milestone-section\"]"
        },
        {
          "action": "click",
          "selector": "[data-testid=\"milestone-section\"] button[aria-label=\"展開里程碑\"]"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assert",
          "check": "text 'Q2 上線' visible"
        },
        {
          "action": "assert",
          "check": "text '待開始' visible"
        },
        {
          "action": "screenshot",
          "name": "ms-05-milestone-in-table"
        }
      ]
    },
    {
      "id": "MS-06",
