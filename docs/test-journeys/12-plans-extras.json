{
  "journey": "plans-extras",
  "version": "1.0.0",
  "description": "Plans page extras — milestone section, goal status toggle, and retrospective generator",
  "baseUrl": "http://localhost:3100",
  "credentials": {
    "ENGINEER": { "email": "engineer@titan.local", "password": "Test1234!", "role": "ENGINEER" },
    "MANAGER": { "email": "manager@titan.local", "password": "Test1234!", "role": "MANAGER" },
    "ADMIN": { "email": "admin@titan.local", "password": "Test1234!", "role": "ADMIN" }
  },
  "testCases": [
    {
      "id": "MS-01",
      "name": "Manager navigates to /plans — milestone section visible",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/plans",
          "expected": "HTTP 200, plans page loads"
        },
        {
          "action": "wait",
          "selector": "h1"
        },
        {
          "action": "assert",
          "check": "URL contains /plans"
        },
        {
          "action": "assert",
          "check": "element '[data-testid=\"milestone-section\"]' visible"
        },
        {
          "action": "screenshot",
          "name": "ms-01-plans-milestone-section-visible"
        }
      ]
    },
    {
      "id": "MS-02",
      "name": "Expand milestone section — 新增里程碑 button and table visible",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/plans",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "[data-testid=\"milestone-section\"]"
        },
        {
          "action": "click",
          "selector": "[data-testid=\"milestone-section\"] button[aria-label=\"展開里程碑\"]"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assert",
          "check": "text '新增里程碑' visible"
        },
        {
          "action": "assert",
          "check": "element '[data-testid=\"milestone-table\"]' visible"
        },
        {
          "action": "screenshot",
          "name": "ms-02-milestone-section-expanded"
        }
      ]
    },
    {
      "id": "MS-03",
      "name": "Click 新增里程碑 — form opens with plan selector, type, title, date",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/plans",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "[data-testid=\"milestone-section\"]"
        },
        {
          "action": "click",
          "selector": "[data-testid=\"milestone-section\"] button[aria-label=\"展開里程碑\"]"
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "click",
          "selector": "button:has-text('新增里程碑')"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "assert",
          "check": "text '新增里程碑' visible"
        },
        {
          "action": "assert",
          "check": "element 'select[aria-label=\"選擇計畫\"]' visible"
        },
        {
          "action": "assert",
          "check": "element 'select[aria-label=\"里程碑類型\"]' visible"
        },
        {
          "action": "assert",
          "check": "element 'input[aria-label=\"里程碑標題\"]' visible"
        },
        {
          "action": "assert",
          "check": "element 'input[aria-label=\"預計完成日期\"]' visible"
        },
        {
          "action": "screenshot",
          "name": "ms-03-milestone-form-open"
        }
      ]
    },
    {
      "id": "MS-04",
      "name": "Create milestone — select plan, type=上線, title=Q2 上線, set date",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/plans",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "[data-testid=\"milestone-section\"]"
        },
        {
          "action": "click",
          "selector": "[data-testid=\"milestone-section\"] button[aria-label=\"展開里程碑\"]"
        },
        {
          "action": "wait",
          "timeout": 500
        },
        {
          "action": "click",
          "selector": "button:has-text('新增里程碑')"
        },
        {
          "action": "wait",
          "timeout": 1000
        },
        {
          "action": "select",
          "selector": "select[aria-label=\"選擇計畫\"]",
          "value": "1"
        },
        {
          "action": "select",
          "selector": "select[aria-label=\"里程碑類型\"]",
          "value": "上線"
        },
        {
          "action": "fill",
          "selector": "input[aria-label=\"里程碑標題\"]",
          "value": "Q2 上線"
        },
        {
          "action": "fill",
          "selector": "input[aria-label=\"預計完成日期\"]",
          "value": "2026-06-30"
        },
        {
          "action": "click",
          "selector": "button[type=\"submit\"]"
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "name": "ms-04-milestone-created"
        }
      ]
    },
    {
      "id": "MS-05",
      "name": "Verify milestone appears in table with 待開始 status",
