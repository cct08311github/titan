          "action": "assert",
          "check": "text 'Q2 上線' visible"
        },
        {
          "action": "select",
          "selector": "[data-testid=\"milestone-table\"] tr:has-text('Q2 上線') select[aria-label=\"里程碑狀態\"]",
          "value": "IN_PROGRESS"
        },
        {
          "action": "wait",
          "timeout": 2000
        },
        {
          "action": "screenshot",
          "name": "ms-06-milestone-status-dropdown-change"
        }
