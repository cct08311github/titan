    {
      "id": "PERM-01",
      "name": "Admin 導覽至 /admin 並點擊「權限」分頁",
      "role": "ADMIN",
      "steps": [
        {
          "action": "navigate",
          "url": "/admin",
          "expected": "URL 為 /admin，頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "h1",
          "expected": "管理後台頁面標題可見"
        },
        {
          "action": "click",
          "selector": "button[role='tab']:has-text('權限'), [data-testid='tab-permissions'], a:has-text('權限')",
          "expected": "點擊「權限」分頁標籤"
        },
        {
          "action": "wait",
          "timeout": 1500,
          "expected": "等待權限分頁內容載入"
        },
        {
          "action": "assert",
          "check": "text '權限' visible",
          "expected": "權限分頁已啟動並顯示"
        },
        {
          "action": "screenshot",
          "name": "perm-01-admin-permissions-tab"
        }
      ]
    },
    {
      "id": "PERM-02",
