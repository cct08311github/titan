{
  "journey": "07-approvals",
  "version": "1.0.0",
  "description": "簽核管理頁面完整測試旅程：建立請求、批准/拒絕、狀態篩選、角色隔離",
  "baseUrl": "http://localhost:3100",
  "credentials": {
    "ENGINEER": {
      "email": "engineer@titan.local",
      "password": "Test1234!",
      "role": "ENGINEER"
    },
    "MANAGER": {
      "email": "manager@titan.local",
      "password": "Test1234!",
      "role": "MANAGER"
    },
    "ADMIN": {
      "email": "admin@titan.local",
      "password": "Test1234!",
      "role": "ADMIN"
    }
  },
  "testCases": [
    {
      "id": "APPR-01",
      "name": "Manager 導覽至 /approvals，頁面載入並顯示「簽核管理」標題",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/approvals",
          "expected": "HTTP 200，頁面載入完成"
        },
        {
          "action": "wait",
          "selector": "h1",
          "expected": "h1 標題可見"
        },
        {
          "action": "assert",
          "check": "text '簽核管理' visible",
          "expected": "標題顯示「簽核管理」"
        },
        {
          "action": "assert",
          "check": "text '管理審批請求與簽核流程' visible",
          "expected": "副標題可見"
        },
        {
          "action": "assert",
          "check": "element 'button:has-text(\"新增請求\")' visible",
          "expected": "「新增請求」按鈕可見"
        },
        {
          "action": "screenshot",
          "name": "appr-01-manager-landing"
        }
      ]
    },
    {
      "id": "APPR-02",
      "name": "Manager 建立簽核請求（類型=任務狀態變更，填寫所有欄位）",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/approvals",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "button:has-text(\"新增請求\")",
          "expected": "「新增請求」按鈕可見"
        },
        {
          "action": "click",
          "selector": "button:has-text(\"新增請求\")",
          "expected": "點擊展開新增簽核請求表單"
        },
        {
          "action": "wait",
          "selector": "h3:has-text(\"新增簽核請求\")",
          "expected": "表單標題「新增簽核請求」可見"
        },
        {
          "action": "select",
          "selector": "select:has(option[value=\"TASK_STATUS_CHANGE\"])",
          "value": "TASK_STATUS_CHANGE",
          "expected": "選擇類型「任務狀態變更」"
        },
        {
          "action": "fill",
          "selector": "input[placeholder=\"e.g. task-123\"]",
          "value": "task-journey-001",
          "expected": "填入資源 ID"
        },
        {
          "action": "fill",
          "selector": "input[placeholder=\"e.g. TASK\"]",
          "value": "TASK",
          "expected": "填入資源類型"
        },
        {
          "action": "fill",
          "selector": "textarea[placeholder=\"說明申請原因...\"]",
          "value": "J07-E2E 旅程測試：任務狀態由進行中變更為已完成",
          "expected": "填入申請原因"
        },
        {
          "action": "click",
          "selector": "button[type=\"submit\"]:has-text(\"送出請求\")",
          "expected": "點擊送出請求"
        },
        {
          "action": "wait",
          "timeout": 2000,
          "expected": "等待 API 回應"
        },
        {
          "action": "assert",
          "check": "text '已建立簽核請求' visible",
          "expected": "成功 toast 顯示「已建立簽核請求」"
        },
        {
          "action": "screenshot",
          "name": "appr-02-new-request-submitted"
        }
      ]
    },
    {
      "id": "APPR-03",
      "name": "驗證新建立的請求出現在表格中，狀態為「待審核」",
      "role": "MANAGER",
      "steps": [
        {
          "action": "navigate",
          "url": "/approvals",
          "expected": "HTTP 200"
        },
        {
          "action": "wait",
          "selector": "table",
