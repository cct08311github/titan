          "action": "assert",
          "check": "text '待審核' visible",
          "expected": "新請求狀態為「待審核」"
        },
        {
          "action": "assert",
          "check": "element 'th:has-text(\"類型\")' visible",
          "expected": "表格欄位「類型」可見"
        },
        {
          "action": "assert",
          "check": "element 'th:has-text(\"申請人\")' visible",
          "expected": "表格欄位「申請人」可見"
        },
        {
          "action": "assert",
          "check": "element 'th:has-text(\"狀態\")' visible",
          "expected": "表格欄位「狀態」可見"
        },
        {
          "action": "screenshot",
          "name": "appr-03-pending-in-table"
        }
      ]
    },
