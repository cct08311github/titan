# ============================================
# 銀行 IT 團隊協作平台 - 環境變數
# ============================================
# 請複製此檔案為 .env 並修改以下參數

# PostgreSQL 資料庫
POSTGRES_DB=bankdb
POSTGRES_USER=bankuser
POSTGRES_PASSWORD=bankpass  # 請修改為強密碼

# 安全性金鑰 (請修改為強隨機字串)
SECRET_KEY=your-secret-key-change-in-production
JWT_SECRET=your-jwt-secret-change-in-production

# 時區設定
TZ=Asia/Taipei