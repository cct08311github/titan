# ================================================================
# Plane 環境變數範本
# 任務：T12 — Plane 基礎部署
# 使用方式：複製為 .env，填入實際值後再啟動
# ================================================================
# ⚠️  警告：.env 不可提交至 Git，已加入 .gitignore
# ================================================================

# ----------------------------------------------------------------
# 基本應用程式設定
# ----------------------------------------------------------------

# Plane 版本（建議固定版本號，避免隔離網路無法自動更新）
PLANE_VERSION=0.23.0

# 對外存取 URL（含 port，無尾斜線）
# 範例：http://10.0.1.100:8082
WEB_URL=http://localhost:8082

# 應用程式除錯模式（正式環境設為 0）
DEBUG=0

# Django Secret Key（至少 50 個隨機字元，務必更換）
# 產生指令：python -c "import secrets; print(secrets.token_hex(50))"
SECRET_KEY=change-this-to-a-random-secret-key-at-least-50-chars

# ----------------------------------------------------------------
# 資料庫設定
# ----------------------------------------------------------------

# 選項一：使用 TITAN 共用 PostgreSQL（建議）
# 需先執行：CREATE DATABASE plane_db; CREATE USER plane_user ...
DATABASE_URL=postgresql://plane_user:change_this_password@titan-postgres:5432/plane_db

# 選項二：使用 Plane 獨立 PostgreSQL（若不整合 TITAN）
# DATABASE_URL=postgresql://plane:change_this_password@plane-postgres:5432/plane

# ----------------------------------------------------------------
# Redis / 快取設定
# ----------------------------------------------------------------

# 選項一：使用 TITAN 共用 Redis（DB 1，避免與 Outline 的 DB 0 衝突）
REDIS_URL=redis://:${REDIS_PASSWORD}@titan-redis:6379/1

# 選項二：使用 Plane 獨立 Redis
# REDIS_URL=redis://plane-redis:6379/

# ----------------------------------------------------------------
# 物件儲存設定（MinIO S3 相容）
# ----------------------------------------------------------------

# 選項一：使用 TITAN 共用 MinIO
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=change_this_minio_password
AWS_S3_ENDPOINT_URL=http://titan-minio:9000
AWS_S3_BUCKET_NAME=plane-uploads
# 外部存取 URL（供瀏覽器直接下載附件，需對外可達）
MINIO_EXTERNAL_URL=http://localhost:9000

# 選項二：使用 Plane 獨立 MinIO
# AWS_S3_ENDPOINT_URL=http://plane-minio:9000

# ----------------------------------------------------------------
# 郵件設定（選用，SMTP）
# ----------------------------------------------------------------

# 郵件功能開關（0=關閉，1=開啟）
EMAIL_HOST=smtp.bank.internal
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_PORT=587
EMAIL_USE_TLS=1
EMAIL_FROM=no-reply@titan.bank.internal
DEFAULT_FROM_EMAIL=no-reply@titan.bank.internal

# ----------------------------------------------------------------
# 認證設定
# ----------------------------------------------------------------

# 是否允許使用 Email/密碼登入（建議整合 OIDC 後設為 0）
ENABLE_EMAIL_PASSWORD=1

# 是否允許使用 Google OAuth（隔離網路設為 0）
ENABLE_GOOGLE_OAUTH=0

# 是否允許使用 GitHub OAuth（隔離網路設為 0）
ENABLE_GITHUB_OAUTH=0

# ----------------------------------------------------------------
# OIDC 單一登入設定（整合 Keycloak / 其他 IdP）
# 參考文件：docs/plane-setup.md 第 6 節
# ----------------------------------------------------------------

# 是否啟用 OIDC 登入
ENABLE_OIDC=0

# OIDC Client 設定（由 IdP 管理員提供）
OIDC_CLIENT_ID=plane
OIDC_CLIENT_SECRET=change_this_oidc_secret
OIDC_TOKEN_ENDPOINT=https://keycloak.bank.internal/realms/titan/protocol/openid-connect/token
OIDC_USERINFO_ENDPOINT=https://keycloak.bank.internal/realms/titan/protocol/openid-connect/userinfo
OIDC_AUTH_ENDPOINT=https://keycloak.bank.internal/realms/titan/protocol/openid-connect/auth
OIDC_JWKS_URI=https://keycloak.bank.internal/realms/titan/protocol/openid-connect/certs

# 銀行內部自簽憑證（設為 false 跳過 SSL 驗證，僅限測試環境）
OIDC_SSL_VERIFY=true

# ----------------------------------------------------------------
# Plane Proxy（Nginx）設定
# ----------------------------------------------------------------

# 對外暴露的 Port（避免與 TITAN 其他服務衝突）
NGINX_PORT=8082

# ----------------------------------------------------------------
# 進階設定
# ----------------------------------------------------------------

# 是否啟用遙測資料回傳（隔離網路務必設為 0）
TELEMETRY_ENABLED=0

# 是否允許使用者自行註冊（銀行環境建議設為 0，改用 OIDC 控管）
ALLOW_SIGNUPS=0

# Worker 並發數（依伺服器資源調整）
GUNICORN_WORKERS=2

# ----------------------------------------------------------------
# 僅供參考（不需修改，由 docker-compose 內部使用）
# ----------------------------------------------------------------

# CORS 設定（自動從 WEB_URL 衍生，通常不需修改）
CORS_ALLOWED_ORIGINS=${WEB_URL}
