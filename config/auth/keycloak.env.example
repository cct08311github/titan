# Keycloak OIDC Provider 配置範本
# 複製此檔案並填入實際值

# =============================================
# Keycloak Realm 配置
# =============================================

# Realm 名稱
KEYCLOAK_REALM=titan

# Keycloak URL
KEYCLOAK_URL=https://keycloak.your-domain.com
KEYCLOAK_INTERNAL_URL=http://keycloak:8080

# Admin 帳號
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=<change-me-in-production>

# Database
KC_DB_PASSWORD=<change-me-in-production>

# =============================================
# LDAP/AD 連線配置
# =============================================

# LDAP 伺服器
LDAP_SERVER=ldap.bank.internal
LDAP_PORT=389
LDAP_USE_SSL=false
LDAP_USE_TLS=false

# LDAP Bind DN
LDAP_BIND_DN=cn=admin,dc=bank,dc=local
LDAP_BIND_PASSWORD=<ldap-admin-password>

# LDAP Base DN
LDAP_BASE_DN=dc=bank,dc=local
LDAP_USER_BASE_DN=ou=Users,dc=bank,dc=local
LDAP_GROUP_BASE_DN=ou=Groups,dc=bank,dc=local

# =============================================
# Plane Client 配置
# =============================================

PLANE_CLIENT_ID=plane
PLANE_CLIENT_SECRET=<generate-random-secret>
PLANE_REDIRECT_URI=https://plane.your-domain.com/*

# =============================================
# Outline Client 配置
# =============================================

OUTLINE_CLIENT_ID=outline
OUTLINE_CLIENT_SECRET=<generate-random-secret>
OUTLINE_REDIRECT_URI=https://outline.your-domain.com/auth/oidc.callback

# =============================================
# OIDC 配置 (自動發現)
# =============================================

OIDC_ISSUER_URL=https://keycloak.your-domain.com/realms/titan

# =============================================
# 安全配置
# =============================================

# 密碼策略
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_REQUIRE_UPPER=true

# 登入失敗鎖定
BRUTE_FORCE_PROTECTED=true
MAX_FAILURE_WAIT_SECONDS=900
FAILURE_FACTOR=30

# Session 設定
SSO_SESSION_IDLE_TIMEOUT=1800
SSO_SESSION_MAX_LIFESPAN=86400