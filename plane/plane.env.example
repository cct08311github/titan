# Plane 環境變數配置
# 任務: T12 — Plane 基礎部署
# 使用方式：cp plane.env.example plane.env 並編輯實際值

# ── Debug 與 CORS ────────────────────────────────────────────
DEBUG=0
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8000"

# ── PostgreSQL 資料庫 ────────────────────────────────────────
# 使用 TITAN 共用 PostgreSQL
POSTGRES_USER=titan
POSTGRES_PASSWORD=changeme_strong_password_here
POSTGRES_HOST=postgres
POSTGRES_DB=plane
POSTGRES_PORT=5432
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ── Redis 快取 ────────────────────────────────────────────────
# 使用 TITAN 共用 Redis
REDIS_HOST=redis
REDIS_PORT=6379
# 注意：密碼已透過 REDIS_PASSWORD 環境變數傳遞
REDIS_URL=redis://:${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}/0

# ── MinIO 物件儲存 ────────────────────────────────────────────
# 使用 TITAN 共用 MinIO
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=changeme_minio_password_here
AWS_S3_ENDPOINT_URL=http://minio:9000
AWS_S3_BUCKET_NAME=plane
FILE_SIZE_LIMIT=5242880
SIGNED_URL_EXPIRATION=3600

# ── Web URL 設定 ─────────────────────────────────────────────
WEB_URL=http://localhost:8000

# ── Worker 數量 ──────────────────────────────────────────────
GUNICORN_WORKERS=2

# ── Base URLs ───────────────────────────────────────────────
ADMIN_BASE_URL=http://localhost:3001
ADMIN_BASE_PATH=/god-mode
SPACE_BASE_URL=http://localhost:3002
SPACE_BASE_PATH=/spaces
APP_BASE_URL=http://localhost:3000
APP_BASE_PATH=
LIVE_BASE_URL=http://localhost:3100
LIVE_BASE_PATH=/live

# ── 其他設定 ────────────────────────────────────────────────
USE_MINIO=1
DOCKERIZED=1
HARD_DELETE_AFTER_DAYS=60
MINIO_ENDPOINT_SSL=0
API_KEY_RATE_LIMIT=60/minute
LIVE_SERVER_SECRET_KEY=changeme_live_secret_key_here
